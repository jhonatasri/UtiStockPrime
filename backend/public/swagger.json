                  "ativo": {
                    "default": true,
                    "type": "boolean"
                  },
                  "responsavelNome": {
                    "type": "string"
                  },
                  "responsavelTelefone": {
                    "type": "string"
                  },
                  "responsavelEmail": {
                    "type": "string"
                  },
                  "usuariosIds": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  }
                },
                "required": [
                  "nome",
                  "categoria"
                ]
              }
            }
          },
          "required": true
