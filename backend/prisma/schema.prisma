// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client" // enable Prisma ORM without Rust
}

datasource db {
  provider = "mysql"
  // url      = env("DATABASE_URL")
}

enum FuncaoTypes {
  ADMINISTRADOR
  GESTOR
  COORDENADOR_BAR
  COORDENADOR_ESTOQUE
}

enum TipoArmazenamento {
  SECO
  REFRIGERADO
  CONGELADO
  AMBIENTE
}

enum TipoConsumo {
  CONSUMIVEL
  NAO_CONSUMIVEL
  SEMI_CONSUMIVEL
}

enum TipoConsumoDetalhe {
  POR_DOSE
  POR_UNIDADE
  POR_VOLUME
}

model Usuarios {
  id            Int             @id @default(autoincrement())
  nome          String
  email         String          @unique
  ativo         Boolean         @default(true)
  senha         String
  telefone      String
  funcao        FuncaoTypes
  descricao     String?
  rotasUsuarios   RotasUsuarios[]
  eventosUsuarios EventosUsuarios[]
  barUsuarios     BarUsuarios[]
  sangrias        Sangrias[]
  devolucoes      Devolucoes[]

  @@map("usuarios")
}

model Rotas {
  id            Int             @id @default(autoincrement())
  rota          String
  titulo        String
  descricao     String?
  logo          String
  modulo        String?
  rotasUsuarios RotasUsuarios[]

  @@map("rotas")
}

model RotasUsuarios {
  id Int @id @default(autoincrement())

  idRota  Rotas @relation(fields: [rotasId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  rotasId Int

  usuarioId  Usuarios @relation(fields: [usuariosId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  usuariosId Int

  @@map("rotasUsuarios")
}

model Eventos {
  id                  Int               @id @default(autoincrement())
  nome                String
  descricao           String?
  data                DateTime?
  local               String?
  ativo               Boolean           @default(true)
  categoria           String
  responsavelNome     String?
  responsavelTelefone String?
  responsavelEmail    String?
  usuarios            EventosUsuarios[]
  produtos            Produtos[]
  bares               Bares[]
  entradas            Entradas[]
  saidas              Saidas[]
  sangrias            Sangrias[]
  devolucoes          Devolucoes[]

  @@map("eventos")
}

model Produtos {
  id                  Int                @id @default(autoincrement())
  codigo              String             @unique
  nome                String
  categoria           String
  marca               String
  modelo              String?
  descricao           String?
  unidadeMedida       String
  quantidadeMinima    Int                @default(0)
  ativo               Boolean            @default(true)
  tipoArmazenamento   TipoArmazenamento
  tipoConsumo         TipoConsumo
  tipoConsumoDetalhe  TipoConsumoDetalhe
  volumePorUnidade    Float?
  mlPorDose           Float?
  dosesPorUnidade     Float?
  eventoId            Int?
  evento              Eventos?           @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  barProdutos         BarProdutos[]
  entradaItens        EntradaItens[]
  saidaItens          SaidaItens[]
  sangriaItens        SangriaItens[]
  devolucaoItens      DevolucaoItens[]

  @@map("produtos")
}

model Bares {
  id          Int           @id @default(autoincrement())
  nome        String
  liderNome   String?
  area        String?
  setor       String?
  descricao   String?
  status      String        @default("FECHADO")
  ativo       Boolean       @default(false)
  eventoId    Int?
  evento      Eventos?      @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  produtos    BarProdutos[]
  entradaItens EntradaItens[]
  saidaItens   SaidaItens[]
  barUsuarios  BarUsuarios[]
  sangrias     Sangrias[]
  devolucoes   Devolucoes[]

  @@map("bares")
}

model Sangrias {
  id          Int            @id @default(autoincrement())
  barId       Int
  usuarioId   Int?
  responsavel String
  dataHora    DateTime       @default(now())
  status      String         @default("ABERTA")
  valorTotal  Float          @default(0)
  eventoId    Int?

  bar     Bares          @relation(fields: [barId], references: [id])
  usuario Usuarios?      @relation(fields: [usuarioId], references: [id])
  evento  Eventos?       @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  itens   SangriaItens[]

  @@map("sangrias")
}

model SangriaItens {
  id         Int @id @default(autoincrement())
  sangriaId  Int
  produtoId  Int
  quantidade Int

  sangria Sangrias @relation(fields: [sangriaId], references: [id], onDelete: Cascade)
  produto Produtos @relation(fields: [produtoId], references: [id])

  @@map("sangriaItens")
}

model BarUsuarios {
  id        Int      @id @default(autoincrement())
  barId     Int
  usuarioId Int

  bar     Bares    @relation(fields: [barId], references: [id], onDelete: Cascade)
  usuario Usuarios @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([barId, usuarioId])
  @@map("barUsuarios")
}

model BarProdutos {
  id        Int      @id @default(autoincrement())
  barId     Int
  produtoId Int

  bar     Bares    @relation(fields: [barId], references: [id], onDelete: Cascade)
  produto Produtos @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([barId, produtoId])
  @@map("barProdutos")
}

model Entradas {
  id              Int            @id @default(autoincrement())
  dataHora        DateTime       @default(now())
  tipoEntrada     String
  numeroDocumento String?
  fornecedor      String?
  observacoes     String?
  eventoId        Int?
  evento          Eventos?       @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  itens           EntradaItens[]

  @@map("entradas")
}

model EntradaItens {
  id          Int       @id @default(autoincrement())
  entradaId   Int
  produtoId   Int
  barId       Int
  loteSerie   String?
  validade    DateTime?
  quantidade  Int
  precoVenda  Float
  localizacao String?

  entrada Entradas @relation(fields: [entradaId], references: [id], onDelete: Cascade)
  produto Produtos @relation(fields: [produtoId], references: [id])
  bar     Bares    @relation(fields: [barId], references: [id])

  @@map("entradaItens")
}

model Saidas {
  id              Int           @id @default(autoincrement())
  dataHora        DateTime      @default(now())
  tipoSaida       String
  numeroDocumento String?
  observacoes     String?
  eventoId        Int?
  evento          Eventos?      @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  itens           SaidaItens[]

  @@map("saidas")
}

model SaidaItens {
  id          Int      @id @default(autoincrement())
  saidaId     Int
  produtoId   Int
  barId       Int
  quantidade  Int
  motivo      String?
  localizacao String?

  saida   Saidas   @relation(fields: [saidaId], references: [id], onDelete: Cascade)
  produto Produtos @relation(fields: [produtoId], references: [id])
  bar     Bares    @relation(fields: [barId], references: [id])

  @@map("saidaItens")
}

model EventosUsuarios {
  id         Int      @id @default(autoincrement())
  eventoId   Int
  usuariosId Int

  evento   Eventos  @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  usuario  Usuarios @relation(fields: [usuariosId], references: [id], onDelete: Cascade)

  @@map("eventosUsuarios")
}

model Devolucoes {
  id          Int              @id @default(autoincrement())
  barId       Int
  usuarioId   Int?
  responsavel String
  dataHora    DateTime         @default(now())
  observacoes String?
  eventoId    Int?

  bar     Bares            @relation(fields: [barId], references: [id])
  usuario Usuarios?        @relation(fields: [usuarioId], references: [id])
  evento  Eventos?         @relation(fields: [eventoId], references: [id], onDelete: SetNull)
  itens   DevolucaoItens[]

  @@map("devolucoes")
}

model DevolucaoItens {
  id          Int @id @default(autoincrement())
  devolucaoId Int
  produtoId   Int
  quantidade  Int

  devolucao Devolucoes @relation(fields: [devolucaoId], references: [id], onDelete: Cascade)
  produto   Produtos   @relation(fields: [produtoId], references: [id])

  @@map("devolucaoItens")
}
