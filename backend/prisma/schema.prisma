// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client" // enable Prisma ORM without Rust
}

datasource db {
  provider = "mysql"
  // url      = env("DATABASE_URL")
}

enum FuncaoTypes {
  ADMINISTRADOR
  GESTOR
  COORDENADOR_BAR
  COORDENADOR_ESTOQUE
}

enum TipoArmazenamento {
  SECO
  REFRIGERADO
  CONGELADO
  AMBIENTE
}

enum TipoConsumo {
  CONSUMIVEL
  NAO_CONSUMIVEL
  SEMI_CONSUMIVEL
}

enum TipoConsumoDetalhe {
  POR_DOSE
  POR_UNIDADE
  POR_VOLUME
}

model Usuarios {
  id            Int             @id @default(autoincrement())
  nome          String
  email         String          @unique
  ativo         Boolean         @default(true)
  senha         String
  telefone      String
  funcao        FuncaoTypes
  descricao     String?
  rotasUsuarios   RotasUsuarios[]
  eventosUsuarios EventosUsuarios[]

  @@map("usuarios")
}

model Rotas {
  id            Int             @id @default(autoincrement())
  rota          String
  titulo        String
  descricao     String?
  logo          String
  modulo        String?
  rotasUsuarios RotasUsuarios[]

  @@map("rotas")
}

model RotasUsuarios {
  id Int @id @default(autoincrement())

  idRota  Rotas @relation(fields: [rotasId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  rotasId Int

  usuarioId  Usuarios @relation(fields: [usuariosId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  usuariosId Int

  @@map("rotasUsuarios")
}

model Eventos {
  id                  Int               @id @default(autoincrement())
  nome                String
  descricao           String?
  data                DateTime?
  local               String?
  ativo               Boolean           @default(true)
  categoria           String
  responsavelNome     String?
  responsavelTelefone String?
  responsavelEmail    String?
  usuarios            EventosUsuarios[]

  @@map("eventos")
}

model Produtos {
  id                  Int                @id @default(autoincrement())
  codigo              String             @unique
  nome                String
  categoria           String
  marca               String
  modelo              String?
  descricao           String?
  unidadeMedida       String
  quantidadeMinima    Int                @default(0)
  ativo               Boolean            @default(true)
  tipoArmazenamento   TipoArmazenamento
  tipoConsumo         TipoConsumo
  tipoConsumoDetalhe  TipoConsumoDetalhe
  volumePorUnidade    Float?
  mlPorDose           Float?
  dosesPorUnidade     Float?

  @@map("produtos")
}

model EventosUsuarios {
  id         Int      @id @default(autoincrement())
  eventoId   Int
  usuariosId Int

  evento   Eventos  @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  usuario  Usuarios @relation(fields: [usuariosId], references: [id], onDelete: Cascade)

  @@map("eventosUsuarios")
}
